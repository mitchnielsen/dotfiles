# Neovim
.config/nvim/.luarc.json
.config/nvim/lazy-lock.json

# K9s
.config/k9s/clusters/
.config/k9s/benchmarks
.config/k9s/screen-dumps

# Lazygit
.config/lazygit/state.yml

# Homebrew
.config/brew/Brewfile.lock.json

# zsh
.config/zsh/.zcompdump
.config/zsh/.zsh_history
.config/zsh/.zsh_sessions
.config/zsh/.zcompcache
*.zwc

# Karabiner Elements
.config/karabiner/automatic_backups

# tmux
.config/tmux/plugins/

# Pi
.config/pi/auth.json
.config/pi/sessions/

# Docker Compose
.env

# Glide
.config/glide/glide.d.ts
.config/glide/tsconfig.json
.config/glide/package.json

# worktrunk
.config/worktrunk/config.toml.lock

# Codex
.config/codex/*
!.config/codex/
!.config/codex/config.toml

# Claude — only the four files below are tracked. Everything else under
# .config/claude is Claude Code runtime state that lives in ~/.config/claude
# (a real directory, not a stow symlink to this repo). Ignoring everything
# else defends against stale setups where the symlink still points here.
.config/claude/*
!.config/claude/CLAUDE.md
!.config/claude/mcp.json
!.config/claude/settings.json
!.config/claude/statusline-command.sh
