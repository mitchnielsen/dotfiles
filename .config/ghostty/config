# https://ghostty.org/docs/config/reference
# https://ghostty.zerebos.com

theme = clarity

# Font settings
font-size = 14
font-family = "SFMono Nerd Font"
adjust-cell-height = "15%"

# Cursor settings
cursor-style = block

# window settings
maximize = true
macos-titlebar-style = hidden
window-padding-x = 15
window-padding-y = 15
quit-after-last-window-closed = true

# Keybindings
# https://www3.rocketsoftware.com/bluezone/help/v42/en/bzadmin/APPENDIX_C/ASCII_Character_Set.htm

# Switch to tmux pane
keybind = cmd+physical:one=text:\x02\x31
keybind = cmd+physical:two=text:\x02\x32
keybind = cmd+physical:three=text:\x02\x33
keybind = cmd+physical:four=text:\x02\x34
keybind = cmd+physical:five=text:\x02\x35

# edit tmux pane
keybind = cmd+y=write_scrollback_file:open

# For some reason this writes a `#`.
keybind = cmd+shift+3=ignore

# Pane/window management
keybind = cmd+w=text:\x02\x78
keybind = cmd+t=text:\x02\x63
keybind = cmd+s=text:\x02\x25
keybind = cmd+i=text:\x02\x22

# Next/Previous pane
keybind = cmd+shift+left_bracket=text:\x02\x70
keybind = cmd+shift+right_bracket=text:\x02\x6E

# Clear screen
keybind = cmd+k=text:\x0c

# Other settings
alpha-blending = linear-corrected
mouse-hide-while-typing = "true"
