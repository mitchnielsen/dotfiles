{
  "mcpServers": {
    "grafana": {
      "type": "http",
      "url": "http://localhost:8100/mcp"
    },
    "prometheus-prd": {
      "type": "http",
      "url": "http://localhost:8101/mcp"
    },
    "prometheus-dev": {
      "type": "http",
      "url": "http://localhost:8103/mcp"
    },
    "prometheus-stg": {
      "type": "http",
      "url": "http://localhost:8104/mcp"
    },
    "terraform": {
      "type": "http",
      "url": "http://localhost:8102/mcp"
    },
    "prefect-prd": {
      "type": "http",
      "url": "http://localhost:8105/mcp"
    },
    "prefect-dev": {
      "type": "http",
      "url": "http://localhost:8106/mcp"
    },
    "prefect-stg": {
      "type": "http",
      "url": "http://localhost:8107/mcp"
    },
    "linear": {
      "type": "http",
      "url": "https://mcp.linear.app/mcp"
    },
    "notion": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp"
    },
    "datadog": {
      "type": "http",
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp?toolsets=core",
      "headers": {
        "DD_API_KEY": "${DD_API_KEY}",
        "DD_APPLICATION_KEY": "${DD_APPLICATION_KEY}"
      }
    },
    "pagerduty": {
      "type": "http",
      "url": "https://mcp.pagerduty.com/mcp",
      "headers": {
        "Authorization": "Token ${PAGERDUTY_TOKEN}"
      }
    }
  }
}
