{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "USE_BUILTIN_RIPGREP": "0",
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "LS(*)",
      "MultiEdit(*)",
      "Read(*)",
      "Task(*)",
      "TodoWrite(*)",
      "WebFetch",
      "WebSearch",
      "Write(*)",
      "mcp__clickhouse",
      "mcp__linear",
      "mcp__pagerduty",
      "mcp__prefect",
      "mcp__prefect-docs",
      "mcp__prometheus-prd",
      "mcp__prometheus-dev",
      "mcp__prometheus-stg",
      "mcp__grafana",
      "mcp__terraform"
    ],
    "ask": [
      "Bash(rm:*)"
    ],
    "deny": [
      "EnterWorktree"
    ]
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.config/claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "prefect-internal-skills@prefecthq-internal-skills": true,
    "visual-explainer@visual-explainer-marketplace": true,
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "prefecthq-internal-skills": {
      "source": {
        "source": "github",
        "repo": "prefecthq/internal-skills"
      }
    },
    "visual-explainer-marketplace": {
      "source": {
        "source": "github",
        "repo": "nicobailon/visual-explainer"
      }
    }
  },
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754598531219
  },
  "theme": "light",
  "editorMode": "vim",
  "preferredNotifChannel": "notifications_disabled",
  "terminalProgressBarEnabled": false
}
