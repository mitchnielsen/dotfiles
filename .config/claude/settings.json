{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "USE_BUILTIN_RIPGREP": "0"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash",
      "Bash(wt:*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "LS(*)",
      "MultiEdit(*)",
      "Read(*)",
      "Skill(*)",
      "Task(*)",
      "TodoWrite(*)",
      "WebFetch",
      "WebSearch",
      "Write(*)",
      "mcp__clickhouse",
      "mcp__grafana",
      "mcp__linear",
      "mcp__pagerduty",
      "mcp__prefect-dev-integration-tests",
      "mcp__prefect-stg-integration-tests",
      "mcp__prefect-prd-integration-tests",
      "mcp__prefect-prd-integration-tests-oss",
      "mcp__prefect-prd-integration-tests-horizon",
      "mcp__prefect-customer-managed",
      "mcp__prometheus",
      "mcp__terraform"
    ],
    "deny": [
      "EnterWorktree"
    ]
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/mitch/.config/claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.config/claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "prefect-internal-skills@prefecthq-internal-skills": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "visual-explainer@visual-explainer-marketplace": true
  },
  "extraKnownMarketplaces": {
    "prefecthq-internal-skills": {
      "source": {
        "source": "github",
        "repo": "prefecthq/internal-skills"
      }
    },
    "visual-explainer-marketplace": {
      "source": {
        "source": "github",
        "repo": "nicobailon/visual-explainer"
      }
    }
  },
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": false,
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "editorMode": "vim",
  "preferredNotifChannel": "notifications_disabled",
  "terminalProgressBarEnabled": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754598531219
  }
}
