{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "USE_BUILTIN_RIPGREP": "0"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "LS(*)",
      "MultiEdit(*)",
      "Read(*)",
      "Task(*)",
      "TodoWrite(*)",
      "WebFetch",
      "WebSearch",
      "Write(*)",
      "mcp__mcp-router",
      "mcp__linear",
      "mcp__pagerduty",
      "mcp__prefect-docs",
      "mcp__prometheus",
      "mcp__grafana"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(git push:*)"
    ]
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.config/claude/statusline-command.sh"
  },
  "extraKnownMarketplaces": {
    "prefecthq-internal-skills": {
      "source": {
        "source": "github",
        "repo": "prefecthq/internal-skills"
      }
    }
  },
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754598531219
  },
  "enabledPlugins": {
    "prefect-internal-skills@prefecthq-internal-skills": true
  }
}
