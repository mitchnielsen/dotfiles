# Entry point for `brew bundle`. Brewfiles are just Ruby, so this pulls in the
# common packages plus whichever machine-specific overlay applies -- see
# https://github.com/Homebrew/homebrew-bundle/issues/1633#issuecomment-2701620454
#
# Do not `brew bundle dump --force` over this file; it will destroy the includes
# below. Use the homebrew:backup mise task instead (dumps to Brewfile.snapshot).

instance_eval(File.read(File.join(__dir__, "Brewfile.common")))

if File.exist?(File.expand_path("~/.personal_device_marker"))
  instance_eval(File.read(File.join(__dir__, "Brewfile.personal")))
else
  instance_eval(File.read(File.join(__dir__, "Brewfile.work")))
end
