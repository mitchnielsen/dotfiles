{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "terraform *": "ask",
      "rm *": "ask",
      "git *": "ask",
      "*": "allow"
    },
    "mcp__clickhouse_*": "allow",
    "mcp__grafana_*": "allow",
    "mcp__linear_*": "allow",
    "mcp__mcp-router_*": "allow",
    "mcp__pagerduty_*": "allow",
    "mcp__prefect-docs_*": "allow",
    "mcp__prometheus-dev_*": "allow",
    "mcp__prometheus-prd_*": "allow",
    "mcp__prometheus-stg_*": "allow",
    "mcp__terraform_*": "allow",
  },
  "mcp": {
    "mcp-router": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@mcp_router/cli@latest",
        "connect"
      ],
      "environment": {}
    },
    "grafana": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:8100/sse"
    },
    "prometheus-prd": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:8101/mcp"
    },
    "prometheus-dev": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:8103/mcp"
    },
    "prometheus-stg": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:8104/mcp"
    },
    "notion": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    },
    "datadog": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp"
    },
    "pagerduty": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.pagerduty.com/mcp",
      "headers": {
        "Authorization": "Token {env:PAGERDUTY_TOKEN}"
      }
    }
  }
}
