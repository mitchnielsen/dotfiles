{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "terraform *": "ask",
      "rm *": "ask",
      "git *": "ask",
      "*": "allow"
    },
    "mcp__clickhouse_*": "allow",
    "mcp__datadog_*": "allow",
    "mcp__grafana_*": "allow",
    "mcp__linear_*": "allow",
    "mcp__pagerduty_*": "allow",
    "mcp__prefect-dev_*": "allow",
    "mcp__prefect-docs_*": "allow",
    "mcp__prefect-prd_*": "allow",
    "mcp__prefect-stg_*": "allow",
    "mcp__prometheus-dev_*": "allow",
    "mcp__prometheus-prd_*": "allow",
    "mcp__prometheus-stg_*": "allow",
    "mcp__terraform_*": "allow"
  },
  "mcp": {
    "grafana": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:8100/mcp"
    },
    "prometheus-prd": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:8101/mcp"
    },
    "prometheus-dev": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:8103/mcp"
    },
    "prometheus-stg": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:8104/mcp"
    },
    "notion": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    },
    "datadog": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp?toolsets=core",
      "headers": {
        "DD_API_KEY": "{env:DD_API_KEY}",
        "DD_APPLICATION_KEY": "{env:DD_APPLICATION_KEY}"
      }
    },
    "pagerduty": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.pagerduty.com/mcp",
      "headers": {
        "Authorization": "Token {env:PAGERDUTY_TOKEN}"
      }
    },
    "terraform": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:8102/mcp"
    },
    "prefect-prd": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:8105/mcp"
    },
    "prefect-dev": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:8106/mcp"
    },
    "prefect-stg": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:8107/mcp"
    },
    "linear": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    }
  }
}
