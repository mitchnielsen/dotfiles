#!/usr/bin/env bash

# git worktree remove: changes back to the
# default branch directory and removes the PR
# branch directory.
#
# Because we use 'cd' in this script, it needs to be
# sourced instead of called directly:
#
#  source ~/bin/git-worktree-remove
#
# Set this as an alias for easy usage.

branch_name=$(git symbolic-ref --short HEAD)
worktree_name=$(basename "${PWD}")
default_branch_name=$(git default-branch)

# Abort if Terraform state directory exists
if [ -d './.terraform' ]; then
  echo 'Error: Terraform directory exists, aborting...'
  return 1
fi

# Use explicit argument, or fall back to default branch
parent_branch="${1:-${default_branch_name}}"

# Verify the target worktree directory exists
if [ ! -d "../${parent_branch}" ]; then
  echo "Error: worktree directory ../${parent_branch} does not exist"
  echo "Available sibling worktrees:"
  ls -d ../*/  2>/dev/null | sed 's|\.\./||; s|/||'
  return 1
fi

cd ../"${parent_branch}" || { echo "Error: could not cd to ../${parent_branch}"; return 1; }
git worktree remove "${worktree_name}"
git branch -D "${branch_name}"
