#!/usr/bin/env bash
# clarity-mode {light|dark|auto} — flip macOS system appearance and sync tools
# that don't natively follow it (tmux, k9s, opencode).
#
# light/dark also set system appearance via osascript, so ghostty/wezterm/
# nvim/claude (which follow the OS) end up consistent.
# auto reads current appearance and only updates the tool configs.

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: clarity-mode {light|dark|auto}

  light  Set macOS to light mode and apply clarity-light to tools
  dark   Set macOS to dark mode and apply clarity-dark to tools
  auto   Detect current macOS appearance and apply the matching variant
         (no system change)

Sets macOS system appearance (light/dark) and syncs tmux, k9s, opencode.
EOF
}

# BSD sed -i on a symlink replaces the symlink with a regular file, breaking
# the link to the dotfiles repo. Resolve to the real path first so we edit the
# actual file the link points at and the symlink survives.
sed_inplace() {
  local file
  file=$(readlink -f "$1")
  shift
  sed -i.bak -E "$@" "$file"
  rm -f "${file}.bak"
}

if [[ $# -ne 1 ]]; then
  usage >&2
  exit 64
fi

mode=$1
set_system_appearance=false
case $mode in
  light|dark)
    variant=$mode
    set_system_appearance=true
    ;;
  auto)
    if defaults read -g AppleInterfaceStyle 2>/dev/null | grep -qi dark; then
      variant=dark
    else
      variant=light
    fi
    ;;
  -h|--help) usage; exit 0 ;;
  *) usage >&2; exit 64 ;;
esac

# Flip macOS system appearance so ghostty/wezterm/nvim/claude (which follow
# the OS) end up consistent with the tools we update below.
if [[ $set_system_appearance == true ]]; then
  if [[ $variant == dark ]]; then
    osa_dark=true
  else
    osa_dark=false
  fi
  osascript -e "tell application \"System Events\" to tell appearance preferences to set dark mode to ${osa_dark}" >/dev/null
  echo "  ✓ macOS:    system appearance → ${variant}"
fi

config="${XDG_CONFIG_HOME:-$HOME/.config}"

# tmux: swap the clarity-active.conf symlink, then re-source if a server is up.
tmux_active="$config/tmux/clarity-active.conf"
ln -sfn "clarity-${variant}.conf" "$tmux_active"
if command -v tmux >/dev/null 2>&1 && tmux info >/dev/null 2>&1; then
  tmux source-file "$config/tmux/tmux.conf" >/dev/null 2>&1 || true
  echo "  ✓ tmux:     re-sourced clarity-${variant}.conf"
else
  echo "  ✓ tmux:     symlink → clarity-${variant}.conf (no server running)"
fi

# k9s: rewrite the `skin:` line in config.yaml. Restart k9s to see the change.
k9s_config="$config/k9s/config.yaml"
if [[ -f $k9s_config ]]; then
  # Match indented `skin: clarity-...` under `ui:`.
  sed_inplace "$k9s_config" "s#^([[:space:]]*skin:[[:space:]]*)clarity-(light|dark)\$#\\1clarity-${variant}#"
  echo "  ✓ k9s:      skin → clarity-${variant} (restart k9s to apply)"
fi

# opencode: rewrite the `"theme": "..."` line in tui.json.
oc_config="$config/opencode/tui.json"
if [[ -f $oc_config ]]; then
  sed_inplace "$oc_config" "s#(\"theme\":[[:space:]]*\")clarity-(light|dark)(\")#\\1clarity-${variant}\\3#"
  echo "  ✓ opencode: theme → clarity-${variant} (restart opencode to apply)"
fi

# nvim: SIGUSR1 to all running instances. The signal handler in 00-theme.lua
# re-detects appearance and reapplies clarity-light/clarity-dark.
nvim_pids=$(pgrep -x nvim 2>/dev/null || true)
if [[ -n $nvim_pids ]]; then
  # shellcheck disable=SC2086 — word splitting is intended
  kill -USR1 $nvim_pids 2>/dev/null || true
  count=$(echo "$nvim_pids" | wc -l | tr -d ' ')
  echo "  ✓ nvim:     signaled ${count} running instance(s)"
fi

echo
echo "applied: clarity-${variant}"
